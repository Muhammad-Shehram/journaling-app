  <div class="ln-hero__orb ln-hero__orb--2"></div>
  <div class="ln-hero__orb ln-hero__orb--3"></div>

  <div class="ln-hero__content">
    <div class="ln-hero__label">✦ Your private journaling space</div>
    <h1 class="ln-hero__headline">
      Write freely.<br>
      Think <em>clearly.</em>
    </h1>
    <p class="ln-hero__sub">
      A private, beautifully organised space for your thoughts,
      memories, and daily reflections — entirely yours.
    </p>
    <div class="ln-hero__actions">
      <%= link_to "Begin writing — it's free", new_user_registration_path, class: "ln-btn ln-btn--primary" %>
      <%= link_to "Sign in", new_user_session_path, class: "ln-btn ln-btn--ghost" %>
    </div>
    <p class="ln-hero__footnote">No credit card &nbsp;·&nbsp; No ads &nbsp;·&nbsp; No tracking</p>
  </div>

  <a href="#ln-features" class="ln-scroll-hint" aria-label="Scroll to features">↓</a>
</section>

<%# ---- PILLARS ---- %>
<section class="ln-pillars" id="ln-features">

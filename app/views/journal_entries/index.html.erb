<div class="entries"
     style="--journal-color: <%= @journal.color || '#3ABF6A' %>"
     data-controller="entry-search calendar"
     data-calendar-dates-value="<%= @all_entry_dates.to_json %>"
     data-calendar-base-url-value="<%= journal_journal_entries_path(@journal) %>"
     data-calendar-journal-color-value="<%= @journal.color || '#3ABF6A' %>">

  <%# ---- HEADER ---- %>
  <div class="entries__header">
    <div class="entries__header-main">
      <span class="journal-pill" style="--journal-pill-color: <%= @journal.color || '#3ABF6A' %>">
        <%= @journal.name %>
      </span>
      <%= link_to new_journal_journal_entry_path(@journal), class: "entries__new-btn" do %>
        <i class="fa-solid fa-plus"></i> New Entry
      <% end %>
    </div>
  </div>

  <%# ---- SEARCH BAR ---- %>
  <div class="entries__search">
    <div class="entries__search-wrap">
      <i class="fa-solid fa-magnifying-glass entries__search-icon"></i>
      <input type="text"
             placeholder="Search entries…"
             class="entries__search-input"
             autocomplete="off"
             data-entry-search-target="input"
             data-action="input->entry-search#filter">
      <button type="button" class="entries__search-clear" data-entry-search-target="clearBtn" data-action="click->entry-search#clear" style="display:none">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
  </div>

  <%# ---- FILTER BAR ---- %>
  <div class="entries__filters">

    <%# Date range filter %>
    <%= form_with url: journal_journal_entries_path(@journal), method: :get, class: "entries__date-range" do |f| %>
      <span class="entries__filter-label">Date range</span>
      <%= hidden_field_tag :q, params[:q] %>
      <%= date_field_tag :from, params[:from], class: "entries__date-input", "aria-label": "From date" %>
      <span class="entries__date-sep">→</span>
      <%= date_field_tag :to, params[:to], class: "entries__date-input", "aria-label": "To date" %>
      <button type="submit" class="entries__date-apply">Apply</button>
    <% end %>

    <%# Active filter chips (shown only when date filters are active) %>
    <% if params[:from].present? || params[:to].present? %>
      <div class="entries__active-filters">
        <%= link_to journal_journal_entries_path(@journal, q: params[:q]),
                    class: "active-filter-chip" do %>
          <i class="fa-solid fa-calendar"></i>
          <%= params[:from].present? ? Date.parse(params[:from]).strftime("%b %-d") : "Start" %>
          –
          <%= params[:to].present? ? Date.parse(params[:to]).strftime("%b %-d") : "Today" %>
          <i class="fa-solid fa-xmark"></i>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# ---- VIEW TOGGLE ---- %>
  <div class="view-toggle-row">
    <button type="button" class="view-toggle view-toggle--active"
            data-calendar-target="listBtn"
            data-action="click->calendar#showList">
      <i class="fa-solid fa-list"></i> List
    </button>
    <button type="button" class="view-toggle"
            data-calendar-target="calBtn"
            data-action="click->calendar#showCal">
      <i class="fa-regular fa-calendar"></i> Calendar
    </button>
  </div>

  <%# ---- CALENDAR VIEW (hidden by default) ---- %>
  <div class="calendar-view" data-calendar-target="calView" style="display:none">
    <div class="calendar-nav">
      <button type="button" class="cal-nav-btn" data-action="click->calendar#prevMonth">
        <i class="fa-solid fa-chevron-left"></i>
      </button>
      <span class="cal-month-label" data-calendar-target="monthLabel"></span>
      <button type="button" class="cal-nav-btn" data-action="click->calendar#nextMonth">
        <i class="fa-solid fa-chevron-right"></i>
      </button>
    </div>
    <div class="calendar-grid" data-calendar-target="grid"></div>
  </div>

  <%# ---- ENTRY LIST ---- %>
  <div data-calendar-target="listView">
  <% if @journal_entries.any? %>
    <div class="entries__list" data-entry-search-target="list">
      <% @journal_entries.each do |entry| %>
        <div class="entry-card" data-entry-search-target="card">

          <%# Date block %>
          <div class="entry-card__date">
            <span class="entry-card__day"><%= entry.entry_date.strftime("%d") %></span>
            <span class="entry-card__month"><%= entry.entry_date.strftime("%b") %></span>
          </div>

          <%# Main content — clickable %>
          <%= link_to journal_journal_entry_path(@journal, entry), class: "entry-card__link" do %>
            <div class="entry-card__title"><%= entry.title %></div>
            <div class="entry-card__preview"><%= entry.content.to_plain_text.truncate(120) %></div>
            <div class="entry-card__meta">
              <span class="entry-card__time"><%= entry.entry_date.strftime("%B %-d, %Y") %></span>
            </div>
          <% end %>

          <%# Edit / Delete actions %>
          <div class="entry-card__actions">
            <%= link_to edit_journal_journal_entry_path(@journal, entry), class: "entry-action", title: "Edit" do %>
              <i class="fa-solid fa-pen"></i>
            <% end %>
            <%= link_to journal_journal_entry_path(@journal, entry), class: "entry-action entry-action--delete", title: "Delete",
                data: { turbo_method: :delete, turbo_confirm: "Delete \"#{entry.title}\"? This cannot be undone." } do %>
              <i class="fa-solid fa-trash-can"></i>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>

    <%# No results message (shown by Stimulus when search finds nothing) %>
    <div class="entries__no-results" data-entry-search-target="noResults" style="display:none">
      <p>No entries match "<span data-entry-search-target="queryDisplay"></span>"</p>
    </div>

  <% else %>
    <%# ---- EMPTY STATE ---- %>
    <div class="entries__empty">
      <div class="entries__empty-icon">
        <i class="fa-solid fa-pen-to-square"></i>
      </div>
      <div class="entries__empty-title">No entries yet</div>
      <p class="entries__empty-text">
        This journal is waiting for your first thought. Start writing — even a few lines count.
      </p>
      <%= link_to new_journal_journal_entry_path(@journal), class: "entries__new-btn" do %>
        <i class="fa-solid fa-plus"></i> Write Your First Entry
      <% end %>
    </div>
  <% end %>
  </div><%# end listView %>

</div>

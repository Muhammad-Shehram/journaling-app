<% content_for(:title) { "Reflekto — Private Journaling App | Write Freely, Think Clearly" } %>
<% content_for(:head) do %>
  <meta name="description" content="Reflekto is a free, private journaling app. Organize your thoughts across multiple colour-coded journals with rich text, tags, photos, and a distraction-free writing canvas. No ads, no tracking — just you and your words.">
  <meta property="og:title" content="Reflekto — Your Private Journaling Space">
  <meta property="og:description" content="A free, private journaling app with rich text, tags, photos, and a beautiful Day One-style writing canvas.">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Reflekto",
    "description": "A free private journaling web application with rich text editing, multiple journals, tags, and photo attachments.",
    "applicationCategory": "LifestyleApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }
  </script>
<% end %>

<%# ---- NAVBAR ---- %>
<nav class="landing-nav">
  <div class="container d-flex align-items-center justify-content-between">
    <div class="landing-nav__brand">Reflekto</div>
    <div class="landing-nav__actions">
      <%= link_to "Sign In", new_user_session_path, class: "landing-nav__link" %>
      <%= link_to "Get Started", new_user_registration_path, class: "landing-nav__cta" %>
    </div>
  </div>
</nav>

<%# ---- HERO ---- %>
<section class="hero-section">
  <div class="hero-glow hero-glow--top"></div>
  <div class="hero-glow hero-glow--bottom"></div>

  <div class="container position-relative">
    <div class="row justify-content-center text-center">
      <div class="col-lg-8 col-md-10">
        <div class="hero-badge hero-badge--float">✦ Your private journaling space</div>
        <h1 class="hero-title">Your Journal.<br>Your Story.</h1>
        <p class="hero-subtitle">
          Reflekto gives you a private, beautifully organised space to capture
          your thoughts, memories, and daily reflections — all in one place.
        </p>
        <div class="hero-actions">
          <%= link_to "Start Writing Free", new_user_registration_path, class: "btn btn-reflekto-primary" %>
          <%= link_to "Sign In", new_user_session_path, class: "btn btn-reflekto-ghost" %>
        </div>
        <p class="hero-footnote">Free to use &nbsp;·&nbsp; No credit card required</p>
      </div>
    </div>
  </div>

  <a href="#features-start" class="hero-scroll-hint" aria-label="Scroll to features">
    <i class="fa-solid fa-chevron-down"></i>
  </a>
</section>

<%# ---- TRUST BAR ---- %>
<section class="trust-bar" id="features-start">
  <div class="container">
    <div class="row justify-content-center align-items-center g-0">
      <div class="col-auto trust-item">
        <i class="fa-solid fa-lock"></i> End-to-end private
      </div>
      <span class="trust-divider">·</span>
      <div class="col-auto trust-item">
        <i class="fa-solid fa-book-open"></i> Multiple journals
      </div>
      <span class="trust-divider">·</span>
      <div class="col-auto trust-item">
        <i class="fa-solid fa-pen-nib"></i> Rich text &amp; photos
      </div>
      <span class="trust-divider">·</span>
      <div class="col-auto trust-item">
        <i class="fa-solid fa-tags"></i> Tags &amp; search
      </div>
    </div>
  </div>
</section>

<%# ---- FEATURES SECTION ---- %>
<section class="features-section">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-label">Why Reflekto</span>
      <h2 class="section-title">Everything you need to journal well</h2>
      <p class="section-subtitle">Simple, focused tools that get out of the way and let you write.</p>
    </div>

    <%# Primary 3-card row %>
    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fa-solid fa-book-bookmark"></i>
          </div>
          <h3>Multiple Journals</h3>
          <p>Separate colour-coded notebooks for work, travel, personal life, ideas. Your thoughts stay organised across every chapter of your life.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="feature-card feature-card--dark">
          <div class="feature-icon feature-icon--light">
            <i class="fa-solid fa-lock"></i>
          </div>
          <h3>Completely Private</h3>
          <p>Your journal belongs only to you. No sharing, no algorithms, no ads. Just your thoughts and a blank page — exactly as it should be.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fa-solid fa-pen-nib"></i>
          </div>
          <h3>Distraction-Free Writing</h3>
          <p>A full-screen writing surface that gets out of the way. Rich text formatting, your choice of font, and a clean design that makes writing feel effortless.</p>
        </div>
      </div>
    </div>

    <%# Secondary feature strip %>
    <div class="row g-3 justify-content-center">
      <div class="col-md-5">
        <div class="feature-strip-card">
          <i class="fa-solid fa-tags feature-strip-card__icon"></i>
          <div>
            <h4>Tags &amp; Search</h4>
            <p>Tag entries with anything that matters. Filter and search across all your journals in seconds.</p>
          </div>
        </div>
      </div>
      <div class="col-md-5">
        <div class="feature-strip-card">
          <i class="fa-solid fa-image feature-strip-card__icon"></i>
          <div>
            <h4>Photo Memories</h4>
            <p>Attach a cover photo to any entry. Your memories deserve more than just words.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ---- HOW IT WORKS ---- %>
<section class="how-section">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-label">Getting started</span>
      <h2 class="section-title">Start in 60 seconds</h2>
    </div>

    <div class="row align-items-start justify-content-center">
      <div class="col-md-3 text-center how-step">
        <div class="step-number">01</div>
        <h4>Create an account</h4>
        <p>Sign up free. No credit card, no nonsense. You're writing within seconds.</p>
      </div>

      <div class="col-md-1 step-arrow d-none d-md-flex">
        <i class="fa-solid fa-arrow-right"></i>
      </div>

      <div class="col-md-3 text-center how-step">
        <div class="step-number">02</div>
        <h4>Create a journal</h4>
        <p>Name it whatever fits — "Daily Log", "Travel", "Work Notes". Pick a colour, make it yours.</p>
      </div>

      <div class="col-md-1 step-arrow d-none d-md-flex">
        <i class="fa-solid fa-arrow-right"></i>
      </div>

      <div class="col-md-3 text-center how-step">
        <div class="step-number">03</div>
        <h4>Start writing</h4>
        <p>Add tags, attach photos, format freely. Your story starts today — and it's entirely yours.</p>
      </div>
    </div>
  </div>
</section>

<%# ---- QUOTE SECTION ---- %>
<section class="quote-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7 text-center">
        <blockquote class="landing-quote">
          "The act of writing is the act of discovering what you believe."
        </blockquote>
        <cite class="landing-cite">— David Hare</cite>
      </div>
    </div>
  </div>
</section>

<%# ---- FINAL CTA ---- %>
<section class="cta-section">
  <div class="container text-center">
    <h2>Ready to start your journal?</h2>
    <p>Your story is worth keeping. Start today — it's free.</p>
    <%= link_to "Create your free journal", new_user_registration_path, class: "btn btn-cta-light" %>
  </div>
</section>

<%# ---- FOOTER ---- %>
<footer class="landing-footer">
  <div class="container">
    <div class="footer-columns">
      <div class="footer-col">
        <p class="footer-col__heading">Legal</p>
        <%= link_to "Terms of Service", terms_path, class: "footer-col__link" %>
        <%= link_to "Privacy Policy", privacy_path, class: "footer-col__link" %>
      </div>
      <div class="footer-col">
        <p class="footer-col__heading">Company</p>
        <%= link_to "About Us", "#", class: "footer-col__link" %>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Reflekto. All rights reserved.</span>
    </div>
  </div>
</footer>

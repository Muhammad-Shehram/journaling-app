<div class="settings-page">

  <div class="settings-header">
    <h1 class="settings-header__title">Settings</h1>
    <p class="settings-header__sub">Manage your account and preferences</p>
  </div>

  <%# ======================================== %>
  <%# ACCOUNT %>
  <%# ======================================== %>
  <div class="settings-section-label">Account</div>

  <section class="settings-card" id="profile">
    <div class="settings-card__header">
      <div class="settings-card__icon"><i class="fa-solid fa-user"></i></div>
      <div>
        <h2 class="settings-card__title">Profile</h2>
        <p class="settings-card__desc">Update your display name</p>
      </div>
    </div>
    <%= form_with model: current_user, url: update_profile_settings_path, method: :patch, class: "settings-form" do |f| %>
      <div class="settings-form__row">
        <%= f.label :name, "Display name", class: "settings-form__label" %>
        <%= f.text_field :name, class: "settings-form__input", placeholder: "Your name", autocomplete: "name" %>
      </div>
      <div class="settings-form__row">
        <div class="settings-form__label">Email address</div>
        <div class="settings-email-static"><%= current_user.email %></div>
        <p class="settings-email-static__note">
          <i class="fa-solid fa-circle-info"></i> Email changes coming soon
        </p>
      </div>
      <button type="submit" class="settings-btn settings-btn--primary">Save profile</button>
    <% end %>
  </section>

  <section class="settings-card" id="password">
    <div class="settings-card__header">
      <div class="settings-card__icon"><i class="fa-solid fa-lock"></i></div>
      <div>
        <h2 class="settings-card__title">Password</h2>
        <p class="settings-card__desc">Change your login password</p>
      </div>
    </div>
    <%= form_with model: current_user, url: update_password_settings_path, method: :patch, class: "settings-form" do |f| %>

      <%# Current password %>
      <div class="settings-form__row" data-controller="password">
        <%= f.label :current_password, "Current password", class: "settings-form__label" %>
        <div class="settings-pw-wrap">
          <i class="fa-solid fa-lock settings-pw-icon"></i>
          <%= f.password_field :current_password,
              class: "settings-form__input settings-form__input--pw",
              autocomplete: "current-password",
              placeholder: "Enter current password",
              data: { password_target: "input" } %>
          <button type="button" class="settings-pw-eye"
                  data-password-target="toggleBtn"
                  data-action="click->password#toggle">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
      </div>

      <div class="settings-pw-separator"></div>

      <%# New password + requirements %>
      <div class="settings-form__row" data-controller="password">
        <%= f.label :password, "New password", class: "settings-form__label" %>
        <div class="settings-pw-wrap">
          <i class="fa-solid fa-lock settings-pw-icon"></i>
          <%= f.password_field :password,
              class: "settings-form__input settings-form__input--pw",
              autocomplete: "new-password",
              placeholder: "Create new password",
              data: { password_target: "input", action: "input->password#check" } %>
          <button type="button" class="settings-pw-eye"
                  data-password-target="toggleBtn"
                  data-action="click->password#toggle">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
        <ul class="req-list" data-password-target="list">
          <li class="req-item" data-req="req-length">
            <i class="fa-solid fa-circle-check req-icon"></i> At least 12 characters
          </li>
          <li class="req-item" data-req="req-uppercase">
            <i class="fa-solid fa-circle-check req-icon"></i> One uppercase letter
          </li>
          <li class="req-item" data-req="req-number">
            <i class="fa-solid fa-circle-check req-icon"></i> One number
          </li>
          <li class="req-item" data-req="req-special">
            <i class="fa-solid fa-circle-check req-icon"></i> One special character (!@#$%^&amp;*)
          </li>
        </ul>
      </div>

      <%# Confirm new password %>
      <div class="settings-form__row" data-controller="password">
        <%= f.label :password_confirmation, "Confirm new password", class: "settings-form__label" %>
        <div class="settings-pw-wrap">
          <i class="fa-solid fa-lock settings-pw-icon"></i>
          <%= f.password_field :password_confirmation,
              class: "settings-form__input settings-form__input--pw",
              autocomplete: "new-password",
              placeholder: "Confirm new password",
              data: { password_target: "input" } %>
          <button type="button" class="settings-pw-eye"
                  data-password-target="toggleBtn"
                  data-action="click->password#toggle">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="settings-btn settings-btn--primary">Change password</button>
    <% end %>
  </section>

  <%# ======================================== %>
  <%# REMINDERS %>
  <%# ======================================== %>
  <div class="settings-section-label">Reminders</div>

  <section class="settings-card" id="reminders">
    <div class="settings-card__header">
      <div class="settings-card__icon"><i class="fa-solid fa-bell"></i></div>
      <div>
        <h2 class="settings-card__title">Daily Reminder</h2>
        <p class="settings-card__desc">Get a nudge to write in your journal each day</p>
      </div>
    </div>

    <%= form_with model: current_user, url: update_reminders_settings_path, method: :patch, class: "settings-form" do |f| %>

      <%# Enable toggle %>
      <div class="settings-toggle-row">
        <div>
          <div class="settings-toggle-row__label">Enable daily reminder</div>
          <div class="settings-toggle-row__sub">Receive a reminder to journal each day</div>
        </div>
        <label class="toggle-switch">
          <%= f.check_box :reminders_enabled, class: "toggle-switch__input", id: "reminders_enabled" %>
          <span class="toggle-switch__track"></span>
        </label>
      </div>

      <%# Time %>
      <div class="settings-form__row settings-reminder-time">
        <%= f.label :reminder_time, "Reminder time", class: "settings-form__label" %>
        <%= f.time_field :reminder_time, class: "settings-form__input settings-form__input--time" %>
      </div>

      <%# Day chips %>
      <div class="settings-form__row">
        <div class="settings-form__label">Days</div>
        <div class="settings-day-chips">
          <% active_days = current_user.reminder_days.to_s.split(",") %>
          <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |day| %>
            <label class="settings-day-chip">
              <%= check_box_tag "user[reminder_days_list][]", day,
                                active_days.include?(day),
                                class: "settings-day-chip__input" %>
              <%= day %>
            </label>
          <% end %>
        </div>
      </div>

      <%# Email toggle %>
      <div class="settings-toggle-row">
        <div>
          <div class="settings-toggle-row__label">Send reminder email</div>
          <div class="settings-toggle-row__sub">Email reminders will be available when email delivery is configured</div>
        </div>
        <label class="toggle-switch">
          <%= f.check_box :reminder_email, class: "toggle-switch__input" %>
          <span class="toggle-switch__track"></span>
        </label>
      </div>

      <button type="submit" class="settings-btn settings-btn--primary">Save reminders</button>
    <% end %>
  </section>

  <%# ======================================== %>
  <%# APPEARANCE %>
  <%# ======================================== %>
  <div class="settings-section-label">Appearance</div>

  <section class="settings-card" id="appearance">
    <div class="settings-card__header">
      <div class="settings-card__icon"><i class="fa-solid fa-moon"></i></div>
      <div>
        <h2 class="settings-card__title">Appearance</h2>
        <p class="settings-card__desc">Customise how Reflekto looks</p>
      </div>
    </div>

    <div class="settings-toggle-row"
         data-controller="dark-mode"
         data-dark-mode-url-value="<%= update_appearance_settings_path %>">
      <div>
        <div class="settings-toggle-row__label">Dark mode</div>
        <div class="settings-toggle-row__sub">Switch between light and dark themes</div>
      </div>
      <label class="toggle-switch">
        <%= check_box_tag :dark_mode, "1", current_user.dark_mode,
            class: "toggle-switch__input",
            data: { action: "change->dark-mode#toggle" } %>
        <span class="toggle-switch__track"></span>
      </label>
    </div>
  </section>

  <%# ======================================== %>
  <%# DATA %>
  <%# ======================================== %>
  <div class="settings-section-label">Data</div>

  <section class="settings-card" id="data">
    <div class="settings-card__header">
      <div class="settings-card__icon"><i class="fa-solid fa-download"></i></div>
      <div>
        <h2 class="settings-card__title">Export entries</h2>
        <p class="settings-card__desc">Download all your journal entries as a plain text file</p>
      </div>
    </div>
    <div class="settings-export-row">
      <%= link_to export_settings_path,
                  class: "settings-btn settings-btn--primary",
                  data: { turbo: false } do %>
        <i class="fa-solid fa-file-arrow-down"></i> Export Data
      <% end %>
      <span class="settings-export-row__hint">All entries from all journals, formatted as readable text</span>
    </div>
  </section>

  <%# ======================================== %>
  <%# DANGER ZONE %>
  <%# ======================================== %>
  <div class="settings-section-label settings-section-label--danger">Danger zone</div>

  <section class="settings-card settings-card--danger" id="danger">
    <div class="settings-card__header">
      <div class="settings-card__icon settings-card__icon--danger"><i class="fa-solid fa-triangle-exclamation"></i></div>
      <div>
        <h2 class="settings-card__title">Delete account</h2>
        <p class="settings-card__desc">Permanently delete your account and all journals</p>
      </div>
    </div>
    <p class="settings-danger__warning">
      This action is <strong>irreversible</strong>. All your journals, entries, and data will be permanently deleted.
    </p>

    <div data-controller="delete-account"
         data-delete-account-email-value="<%= current_user.email %>">

      <button type="button"
              class="settings-btn settings-btn--danger"
              data-action="click->delete-account#open">
        <i class="fa-solid fa-trash-can"></i> Delete my account
      </button>

      <%# ── GitHub-style 3-step confirmation modal ── %>
      <div class="delete-modal-overlay"
           data-delete-account-target="overlay"
           data-action="click->delete-account#closeOnBackdrop">
        <div class="delete-modal__box">

          <button class="delete-modal__close" type="button"
                  data-action="click->delete-account#close" aria-label="Close">
            <i class="fa-solid fa-xmark"></i>
          </button>

          <%# Step 1 — Intent %>
          <div data-delete-account-target="step1" class="delete-modal__step">
            <div class="delete-modal__account-icon">
              <i class="fa-solid fa-book-open-reader"></i>
            </div>
            <h3 class="delete-modal__title">Delete account</h3>
            <p class="delete-modal__email-display"><%= current_user.email %></p>
            <button type="button"
                    class="delete-modal__cta"
                    data-action="click->delete-account#advance2">
              I want to delete my account
            </button>
          </div>

          <%# Step 2 — Consequences %>
          <div data-delete-account-target="step2" class="delete-modal__step" hidden>
            <div class="delete-modal__warning-banner">
              <i class="fa-solid fa-triangle-exclamation"></i>
              Unexpected bad things will happen if you don't read this!
            </div>
            <ul class="delete-modal__consequences">
              <li>All your <strong>journals and entries</strong> will be permanently deleted</li>
              <li>All tags and writing history will be gone <strong>forever</strong></li>
              <li>You will be <strong>signed out immediately</strong> — this cannot be undone</li>
            </ul>
            <button type="button"
                    class="delete-modal__cta delete-modal__cta--understood"
                    data-action="click->delete-account#advance3">
              I have read and understand these effects
            </button>
          </div>

          <%# Step 3 — Type email to confirm %>
          <div data-delete-account-target="step3" class="delete-modal__step" hidden>
            <%= form_with url: destroy_account_settings_path, method: :delete, class: "delete-modal__form" do %>
              <p class="delete-modal__confirm-label">
                To confirm, type <strong><%= current_user.email %></strong> in the box below
              </p>
              <input type="text"
                     name="confirm_email"
                     class="delete-modal__email-input"
                     data-delete-account-target="emailInput"
                     data-action="input->delete-account#checkEmail"
                     placeholder="<%= current_user.email %>"
                     autocomplete="off" />
              <button type="submit"
                      class="delete-modal__submit"
                      data-delete-account-target="submitBtn"
                      disabled>
                <i class="fa-solid fa-trash-can"></i> Delete this account
              </button>
            <% end %>
          </div>

        </div>
      </div>
    </div>
  </section>

</div>

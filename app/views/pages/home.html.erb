      </div>
    </div>
  </div>
  <div class="ln-footer__bottom">
    <span>© 2026 Reflekto. All rights reserved.</span>
  </div>
</footer>

<script>
  // Scroll-reveal: add .is-visible when element enters viewport
  (function() {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.ln-reveal').forEach(function(el) { obs.observe(el); });
  })();
</script>

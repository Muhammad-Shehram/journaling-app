  </div>

  <div class="ln-steps">
    <div class="ln-step ln-reveal">
      <div class="ln-step__num">01</div>
      <h4>Create an account</h4>
      <p>Sign up free. No credit card, no nonsense. You're writing within seconds.</p>
    </div>

    <div class="ln-step-arrow" aria-hidden="true">→</div>

    <div class="ln-step ln-reveal">
      <div class="ln-step__num">02</div>
      <h4>Create a journal</h4>
      <p>Name it, colour it, make it yours. "Daily Log", "Travel", "Ideas" — whatever fits.</p>
    </div>

    <div class="ln-step-arrow" aria-hidden="true">→</div>

    <div class="ln-step ln-reveal">
      <div class="ln-step__num">03</div>
      <h4>Start writing</h4>
      <p>Add tags, attach photos, format freely. Your story starts today — and it's entirely yours.</p>
    </div>
  </div>
</section>

<%# ---- FINAL CTA ---- %>
<section class="ln-cta">
  <div class="ln-cta__inner">
    <span class="ln-cta__label">Begin today</span>
    <h2 class="ln-cta__title">Your story is worth<br><em>keeping.</em></h2>
    <p class="ln-cta__sub">Join thousands writing privately, every day.</p>
    <%= link_to "Create your free journal", new_user_registration_path, class: "ln-btn ln-btn--primary" %>
    <p class="ln-cta__footnote">Free forever &nbsp;·&nbsp; No credit card</p>
  </div>
</section>

<%# ---- FOOTER ---- %>

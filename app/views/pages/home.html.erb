<% content_for(:title) { "Reflekto — Private Journaling App | Write Freely, Think Clearly" } %>
<% content_for(:head) do %>
  <meta name="description" content="Reflekto is a free, private journaling app. Organise your thoughts across colour-coded journals with rich text, tags, photos, and a distraction-free writing canvas. No ads, no tracking — just you and your words.">
  <meta property="og:title" content="Reflekto — Your Private Journaling Space">
  <meta property="og:description" content="A free, private journaling app with rich text, tags, photos, and a beautiful distraction-free writing canvas.">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Reflekto",
    "description": "A free private journaling web application with rich text editing, multiple journals, tags, and photo attachments.",
    "applicationCategory": "LifestyleApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }
  </script>
<% end %>

<%# ---- NAV ---- %>
<nav class="ln-nav">
  <div class="ln-nav__inner">
    <div class="ln-nav__brand">Reflekto</div>
    <div class="ln-nav__actions">
      <%= link_to "Sign In", new_user_session_path, class: "ln-nav__link" %>
      <%= link_to "Get Started →", new_user_registration_path, class: "ln-nav__cta" %>
    </div>
  </div>
</nav>

<%# ---- HERO ---- %>

<div class="auth-page">

  <div class="auth-logo">
    <i class="fa-solid fa-book-open-reader"></i>
    <span>Reflekto</span>
  </div>

  <div class="auth-card">
    <h2 class="auth-card__title">Welcome back</h2>
    <p class="auth-card__subtitle">Sign in to continue journaling.</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-inputs">

        <div class="input-group-wrapper">
          <%= f.label :email, "Email address" %>
          <div class="input-wrapper">
            <i class="fa-solid fa-envelope input-icon"></i>
            <%= f.input_field :email,
                              required: false,
                              autofocus: true,
                              autocomplete: "email",
                              placeholder: "you@example.com",
                              class: "auth-input" %>
          </div>
        </div>

        <div class="input-group-wrapper" data-controller="password">
          <%= f.label :password, "Password" %>
          <div class="input-wrapper">
            <i class="fa-solid fa-lock input-icon"></i>
            <%= f.input_field :password,
                              required: false,
                              autocomplete: "current-password",
                              placeholder: "Enter your password",
                              class: "auth-input",
                              data: { password_target: "input" } %>
            <button type="button" class="eye-toggle" data-password-target="toggleBtn" data-action="click->password#toggle">
              <i class="fa-solid fa-eye"></i>
            </button>
          </div>
        </div>

        <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Sign In" %>
      </div>

    <% end %>

    <div class="auth-links">
      <div class="auth-link-row">
        Don't have an account?
        <%= link_to "Create one", new_registration_path(resource_name) %>
      </div>
      <% if devise_mapping.recoverable? %>
        <div class="auth-link-row">
          <%= link_to "Forgot your password?", new_password_path(resource_name) %>
        </div>
      <% end %>
      <%= link_to root_path, class: "auth-back-link" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to Home
      <% end %>
    </div>

  </div>

</div>

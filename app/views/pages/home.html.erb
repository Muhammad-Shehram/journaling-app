<%# ---- FEATURES BENTO ---- %>
<section class="ln-features">
  <div class="ln-features__header">
    <span class="ln-section-tag">Why Reflekto</span>
    <h2 class="ln-features__title">Everything you need<br>to journal <em>well</em></h2>
    <p class="ln-features__sub">Focused tools that get out of the way and let you write.</p>
  </div>

  <div class="ln-bento">

    <%# Card 1 — Dark hero card: Multiple Journals %>
    <div class="ln-bento__card ln-bento__card--dark ln-reveal">
      <div class="ln-card-icon">
        <i class="fa-solid fa-book-bookmark" aria-hidden="true"></i>
      </div>
      <h3>Multiple Journals</h3>
      <p>Separate colour-coded notebooks for every chapter of your life. Work, travel, personal, dreams — all beautifully organised and instantly switchable.</p>
      <div class="ln-card-tag">Colour-coded &middot; Organised</div>
    </div>

    <%# Card 2 — Privacy %>
    <div class="ln-bento__card ln-reveal">
      <div class="ln-card-icon ln-card-icon--forest">
        <i class="fa-solid fa-lock" aria-hidden="true"></i>
      </div>
      <h3>Completely Private</h3>
      <p>Your journal belongs only to you. No sharing, no algorithms, no ads. Just your thoughts and a blank page.</p>
    </div>

    <%# Card 3 — Writing canvas %>
    <div class="ln-bento__card ln-reveal">
      <div class="ln-card-icon ln-card-icon--forest">
        <i class="fa-solid fa-pen-nib" aria-hidden="true"></i>
      </div>
      <h3>Distraction-Free Writing</h3>
      <p>A full-screen canvas that disappears and lets your words take over. Rich text, multiple fonts, total focus.</p>
    </div>

    <%# Card 4 — Tags %>
    <div class="ln-bento__card ln-bento__card--sm ln-reveal">
      <div class="ln-card-icon ln-card-icon--forest">
        <i class="fa-solid fa-tags" aria-hidden="true"></i>
      </div>
      <h3>Tags &amp; Search</h3>
      <p>Tag anything that matters. Filter across all journals in seconds.</p>
    </div>

    <%# Card 5 — Photos %>
    <div class="ln-bento__card ln-bento__card--sm ln-reveal">
      <div class="ln-card-icon ln-card-icon--forest">
        <i class="fa-solid fa-image" aria-hidden="true"></i>
      </div>
      <h3>Photo Memories</h3>
      <p>Attach a cover photo to any entry. Memories deserve more than words.</p>
    </div>

    <%# Card 6 — Prompts %>
    <div class="ln-bento__card ln-bento__card--sm ln-bento__card--accent ln-reveal">
      <div class="ln-card-icon">
        <i class="fa-solid fa-lightbulb" aria-hidden="true"></i>
      </div>
      <h3>Writing Prompts</h3>
      <p>Stuck? 100+ curated prompts across every mood and moment.</p>
    </div>

  </div>
</section>

<%# ---- QUOTE ---- %>
<section class="ln-quote">
  <div class="ln-quote__inner ln-reveal">
    <div class="ln-quote__mark" aria-hidden="true">"</div>

<% cancel_path = @journal_entry.new_record? ?
     journal_journal_entries_path(@journal) :
     journal_journal_entry_path(@journal, @journal_entry) %>

<% date_value = @journal_entry.entry_date.present? ?
     @journal_entry.entry_date.strftime("%Y-%m-%d") :
     Date.today.strftime("%Y-%m-%d") %>

<div class="canvas" data-controller="font-picker" data-font-picker-key-value="reflekto_font">
  <%= simple_form_for([@journal, @journal_entry], html: { class: "canvas__form", multipart: true }) do |f| %>

    <div class="canvas__bar">
      <%= link_to cancel_path, class: "canvas__cancel" do %>
        <i class="fa-solid fa-arrow-left"></i> Cancel
      <% end %>
      <button type="submit" class="canvas__save">
        <%= @journal_entry.new_record? ? "Save Entry" : "Update Entry" %>
      </button>
    </div>

    <div class="canvas__body">

      <%# Context strip: journal name on the left, date chip on the right %>
      <div class="canvas__context">
        <span class="journal-pill" style="--journal-pill-color: <%= @journal.color || '#7C6FF7' %>">
          <%= @journal.name %>
        </span>
        <%= f.text_field :entry_date,
                        type: "date",
                        class: "canvas__date-chip",
                        "aria-label": "Entry date",
                        value: date_value %>
      </div>

      <%# Title %>
      <%= f.input :title,
                  label: false,
                  placeholder: "Title",
                  input_html: {
                    class: "canvas__title-input",
                    autofocus: @journal_entry.new_record?,
                    "aria-label": "Entry title"
                  } %>

      <div class="canvas__divider"></div>

      <%# Rich text content area %>
      <div class="canvas__rich-editor">
        <%= f.rich_text_area :content,
                             placeholder: "Start writing…",
                             class: "canvas__content-input",
                             "aria-label": "Entry content" %>
      </div>

      <%# Photo attachment %>
      <div class="canvas__photo-upload">
        <label class="canvas__photo-label" for="cover_photo_input">
          <i class="fa-solid fa-image"></i>
          <span>Add a photo</span>
        </label>
        <%= f.file_field :cover_photo,
                         id: "cover_photo_input",
                         accept: "image/*",
                         class: "canvas__photo-file-input",
                         "aria-label": "Cover photo" %>
        <% if @journal_entry.cover_photo.attached? %>
          <div class="canvas__photo-preview">
            <%= image_tag @journal_entry.cover_photo, class: "canvas__photo-thumb" %>
            <span class="canvas__photo-filename"><%= @journal_entry.cover_photo.filename %></span>
          </div>
        <% end %>
      </div>

    </div>

  <% end %>

  <%# Aa — floating font picker %>
  <button class="canvas__font-trigger"
          type="button"
          aria-label="Change writing font"
          data-font-picker-target="trigger"
          data-action="click->font-picker#toggle">
    Aa
  </button>

  <div class="canvas__font-popup" data-font-picker-target="popup" role="dialog" aria-label="Formatting options">

    <%# — Fonts — %>
    <div class="canvas__fp-section-label">Fonts</div>
    <% [
      { key: "default", label: "Default",    preview: "The quick brown fox" },
      { key: "serif",   label: "Serif",      preview: "The quick brown fox" },
      { key: "sans",    label: "Sans-serif", preview: "The quick brown fox" },
      { key: "mono",    label: "Monospace",  preview: "const hello = 'world'" }
    ].each do |font| %>
      <button class="canvas__font-option"
              type="button"
              data-font="<%= font[:key] %>"
              data-font-picker-target="option"
              data-action="click->font-picker#select">
        <span class="canvas__font-name"><%= font[:label] %></span>
        <span class="canvas__font-preview canvas__font-preview--<%= font[:key] %>"><%= font[:preview] %></span>
      </button>
    <% end %>

    <div class="canvas__fp-divider"></div>

    <%# — Text Style — %>
    <div class="canvas__fp-section-label">Text Style</div>
    <div class="canvas__fp-grid">
      <button class="canvas__fp-format-btn" type="button"
              title="Bold" data-attr="bold"
              data-action="mousedown->font-picker#format">
        <strong>B</strong>
      </button>
      <button class="canvas__fp-format-btn" type="button"
              title="Italic" data-attr="italic"
              data-action="mousedown->font-picker#format">
        <em>I</em>
      </button>
      <button class="canvas__fp-format-btn canvas__fp-format-btn--strike" type="button"
              title="Strikethrough" data-attr="strike"
              data-action="mousedown->font-picker#format">
        S
      </button>
    </div>

    <div class="canvas__fp-divider"></div>

    <%# — Block Format — %>
    <div class="canvas__fp-section-label">Block Format</div>
    <% [
      { attr: "heading1", label: "Heading",    icon: "fa-heading"    },
      { attr: "quote",    label: "Quote",      icon: "fa-quote-left" },
      { attr: "code",     label: "Code Block", icon: "fa-code"       }
    ].each do |item| %>
      <button class="canvas__fp-row" type="button"
              data-attr="<%= item[:attr] %>"
              data-action="mousedown->font-picker#format">
        <i class="fa-solid <%= item[:icon] %> canvas__fp-row-icon"></i>
        <span><%= item[:label] %></span>
      </button>
    <% end %>

    <div class="canvas__fp-divider"></div>

    <%# — Lists — %>
    <div class="canvas__fp-section-label">Lists</div>
    <% [
      { attr: "bullet", label: "Bullet List",   icon: "fa-list-ul" },
      { attr: "number", label: "Numbered List", icon: "fa-list-ol" }
    ].each do |item| %>
      <button class="canvas__fp-row" type="button"
              data-attr="<%= item[:attr] %>"
              data-action="mousedown->font-picker#format">
        <i class="fa-solid <%= item[:icon] %> canvas__fp-row-icon"></i>
        <span><%= item[:label] %></span>
      </button>
    <% end %>

  </div>

</div>

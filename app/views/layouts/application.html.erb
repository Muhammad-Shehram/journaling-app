<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Reflekto" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= 'dark-mode' if user_signed_in? && current_user.dark_mode %>">
    <% if user_signed_in? %>
      <div class="app-shell" data-controller="sidebar">

        <%# Mobile top bar — hidden on desktop %>
        <div class="app-topbar">
          <button class="app-topbar__hamburger" data-action="click->sidebar#toggle" aria-label="Toggle menu">
            <i class="fa-solid fa-bars"></i>
          </button>
          <span class="app-topbar__brand">Reflekto</span>
        </div>

        <aside class="app-sidebar" data-sidebar-target="panel">
          <div class="app-sidebar__inner">

            <div class="sidebar__toprow">
              <div class="sidebar__brand">Reflekto</div>
              <button class="sidebar__collapse-btn"
                      data-action="click->sidebar#toggleDesktop"
                      title="Toggle sidebar">
                <i class="fa-solid fa-bars"></i>
              </button>
            </div>

            <% if @sidebar_new_entry_journal %>
              <%= link_to new_journal_journal_entry_path(@sidebar_new_entry_journal), class: "sidebar__new-entry-btn" do %>
                <i class="fa-solid fa-plus"></i> New Entry
              <% end %>
            <% else %>
              <%= link_to new_journal_path, class: "sidebar__new-entry-btn" do %>
                <i class="fa-solid fa-plus"></i> New Journal
              <% end %>
            <% end %>

            <%= link_to journals_path,
                        class: "sidebar__nav-item #{'sidebar__nav-item--active' if controller_name == 'journals' && action_name == 'index'}" do %>
              <i class="fa-solid fa-layer-group"></i>
              All Entries
            <% end %>

            <%= link_to prompts_path,
                        class: "sidebar__nav-item #{'sidebar__nav-item--active' if controller_name == 'prompts'}" do %>
              <i class="fa-solid fa-lightbulb"></i>
              Prompts
            <% end %>

            <% if @sidebar_journals.any? %>
              <div class="sidebar__section-label">Journals</div>
              <ul class="sidebar__journal-list">
                <% @sidebar_journals.each do |j| %>
                  <li class="sidebar__journal-item-wrapper">
                    <%= link_to journal_journal_entries_path(j),
                                class: "sidebar__journal-item #{'sidebar__journal-item--active' if params[:journal_id] == j.id.to_s}" do %>
                      <span class="sidebar__journal-dot" style="background: <%= j.color || '#7C6FF7' %>"></span>
                      <span class="sidebar__journal-name"><%= j.name %></span>
                      <span class="sidebar__journal-count"><%= j.journal_entries.active.count %></span>
                    <% end %>
                    <div class="sidebar__journal-actions">
                      <% unless j.is_default? %>
                        <%= link_to edit_journal_path(j), class: "sidebar__journal-action", title: "Edit journal" do %>
                          <i class="fa-solid fa-pen-to-square"></i>
                        <% end %>
                      <% end %>
                      <% unless j.is_default? %>
                        <%= button_to journal_path(j), method: :delete,
                                      class: "sidebar__journal-action sidebar__journal-action--danger",
                                      title: "Delete journal",
                                      data: { turbo_confirm: "Delete \"#{j.name}\" and all its entries? This cannot be undone." } do %>
                          <i class="fa-solid fa-trash-can"></i>
                        <% end %>
                      <% end %>
                    </div>
                  </li>
                <% end %>
              </ul>
            <% end %>

            <%= link_to new_journal_path, class: "sidebar__new-journal" do %>
              <i class="fa-solid fa-plus"></i> New Journal
            <% end %>

            <div class="sidebar__divider"></div>

            <%= link_to recently_deleted_index_path,
                        class: "sidebar__nav-item sidebar__nav-item--muted #{'sidebar__nav-item--active' if controller_name == 'recently_deleted'}" do %>
              <i class="fa-solid fa-trash-can"></i>
              Recently Deleted
              <% if @deleted_count&.> 0 %>
                <span class="sidebar__badge"><%= @deleted_count %></span>
              <% end %>
            <% end %>

            <div class="sidebar__footer">
              <%= link_to settings_path, class: "sidebar__footer-link #{'sidebar__footer-link--active' if controller_name == 'settings'}" do %>
                <i class="fa-solid fa-gear"></i> Settings
              <% end %>
              <%= link_to destroy_user_session_path,
                          class: "sidebar__footer-link",
                          data: { turbo_method: :delete } do %>
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
              <% end %>
            </div>

          </div>
        </aside>

        <main class="app-main">
          <div class="sidebar__overlay" data-action="click->sidebar#close" data-sidebar-target="overlay"></div>


          <% if notice %>
            <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
              <%= notice %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>

          <% if alert %>
            <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
              <%= alert %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% end %>

          <%= yield %>
        </main>

      </div>

    <% else %>
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    <% end %>
  </body>
</html>

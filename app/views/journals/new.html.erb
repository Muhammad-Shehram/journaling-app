<div class="canvas canvas--compact">
  <%= simple_form_for(@journal, html: { class: "canvas__form", data: { controller: "journal-form" } }) do |f| %>

    <div class="canvas__bar">
      <%= link_to journals_path, class: "canvas__cancel" do %>
        <i class="fa-solid fa-arrow-left"></i> Cancel
      <% end %>
      <button type="submit" class="canvas__save">Create Journal</button>
    </div>

    <div class="canvas__body canvas__body--journal-new">

      <%# ---- JOURNAL BOOK PREVIEW ---- %>
      <div class="journal-preview" data-journal-form-target="preview" style="--journal-color: #7C6FF7">
        <div class="journal-preview__spine"></div>
        <div class="journal-preview__cover">
          <i class="fa-solid fa-book-open journal-preview__icon"></i>
        </div>
      </div>

      <%# ---- COLOR SWATCHES ---- %>
      <div class="journal-color-picker">
        <% [
          ["#7C6FF7", "Purple"],
          ["#667EEA", "Indigo"],
          ["#63B3ED", "Blue"],
          ["#4FD1C5", "Teal"],
          ["#68D391", "Green"],
          ["#F6AD55", "Orange"],
          ["#FC8181", "Red"],
          ["#F687B3", "Pink"]
        ].each_with_index do |(hex, label), i| %>
          <button type="button"
                  class="color-swatch <%= 'color-swatch--active' if i == 0 %>"
                  style="background: <%= hex %>"
                  data-color="<%= hex %>"
                  data-action="click->journal-form#selectColor"
                  title="<%= label %>">
          </button>
        <% end %>
        <%= f.hidden_field :color, value: "#7C6FF7", data: { journal_form_target: "colorField" } %>
      </div>

      <%# ---- NAME SUGGESTION CHIPS ---- %>
      <div class="journal-name-chips">
        <% %w[Daily Travel Work Dreams Personal Gratitude Fitness Ideas].each do |name| %>
          <button type="button"
                  class="name-chip"
                  data-name="<%= name %>"
                  data-action="click->journal-form#fillName">
            <%= name %>
          </button>
        <% end %>
      </div>

      <%# ---- NAME INPUT ---- %>
      <%= f.input :name,
                  label: false,
                  placeholder: "Name your journal",
                  input_html: {
                    class: "canvas__title-input",
                    autofocus: true,
                    "aria-label": "Journal name",
                    data: { journal_form_target: "nameInput" }
                  } %>
    </div>

  <% end %>
</div>

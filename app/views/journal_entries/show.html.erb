<div class="canvas">
  <article class="canvas__form">

    <div class="canvas__bar">
      <%= link_to journal_journal_entries_path(@journal), class: "canvas__cancel" do %>
        <i class="fa-solid fa-arrow-left"></i> Back to entries
      <% end %>
      <div class="canvas__bar-actions">
        <%= link_to edit_journal_journal_entry_path(@journal, @journal_entry),
            class: "canvas__icon-btn",
            title: "Edit entry",
            "aria-label": "Edit entry" do %>
          <i class="fa-solid fa-pen"></i>
        <% end %>
        <%= link_to journal_journal_entry_path(@journal, @journal_entry),
            class: "canvas__icon-btn canvas__icon-btn--danger",
            title: "Delete entry",
            "aria-label": "Delete entry",
            data: {
              turbo_method: :delete,
              turbo_confirm: "Delete \"#{@journal_entry.title}\"? This cannot be undone."
            } do %>
          <i class="fa-solid fa-trash-can"></i>
        <% end %>
      </div>
    </div>

    <div class="canvas__body">

      <div class="canvas__context">
        <span class="canvas__context-journal"><%= @journal.name %></span>
        <span class="canvas__context-date">
          <% if @journal_entry.mood.present? %>
            <span class="canvas__context-mood" aria-label="Mood"><%= @journal_entry.mood %></span>
          <% end %>
          <%= @journal_entry.entry_date.strftime("%B %-d, %Y") %>
        </span>
      </div>

      <h1 class="canvas__title-display"><%= @journal_entry.title %></h1>

      <div class="canvas__divider"></div>

      <div class="canvas__content-display">
        <%= simple_format(@journal_entry.content) %>
      </div>

    </div>

  </article>
</div>

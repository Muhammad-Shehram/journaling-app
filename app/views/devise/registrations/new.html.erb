<div class="auth-page">

  <%= link_to root_path, class: "auth-logo" do %>
    <i class="fa-solid fa-book-open-reader"></i>
    <span>Reflekto</span>
  <% end %>

  <div class="auth-card">
    <h2 class="auth-card__title">Create your account</h2>
    <p class="auth-card__subtitle">Start your journaling journey today. It's free.</p>

    <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, class: "google-btn", data: { turbo: false } do %>
      <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continue with Google
    <% end %>

    <div class="auth-divider">
      <span>or sign up with email</span>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

      <%= f.error_notification %>

      <div class="form-inputs">

        <%# Name %>
        <div class="input-group-wrapper">
          <%= f.label :name, "Your name" %>
          <div class="input-wrapper">
            <i class="fa-solid fa-user input-icon"></i>
            <%= f.input_field :name,
                              required: true,
                              autofocus: true,
                              autocomplete: "name",
                              placeholder: "What should we call you?",
                              class: "auth-input" %>
          </div>
        </div>

        <%# Email %>
        <div class="input-group-wrapper">
          <%= f.label :email, "Email address" %>
          <div class="input-wrapper">
            <i class="fa-solid fa-envelope input-icon"></i>
            <%= f.input_field :email,
                              required: true,
                              autocomplete: "email",
                              placeholder: "you@example.com",
                              class: "auth-input" %>
          </div>
        </div>

        <%# Password %>
        <div class="input-group-wrapper" data-controller="password">
          <%= f.label :password, "Password" %>
          <div class="input-wrapper">
            <i class="fa-solid fa-lock input-icon"></i>
            <%= f.input_field :password,
                              required: true,
                              autocomplete: "new-password",
                              placeholder: "Create a password",
                              class: "auth-input",
                              data: { password_target: "input", action: "input->password#check" } %>
            <button type="button" class="eye-toggle" data-password-target="toggleBtn" data-action="click->password#toggle">
              <i class="fa-solid fa-eye"></i>
            </button>
          </div>
          <ul class="req-list" data-password-target="list">
            <li class="req-item" data-req="req-length">
              <i class="fa-solid fa-circle-check req-icon"></i> At least 12 characters
            </li>
            <li class="req-item" data-req="req-uppercase">
              <i class="fa-solid fa-circle-check req-icon"></i> One uppercase letter
            </li>
            <li class="req-item" data-req="req-number">
              <i class="fa-solid fa-circle-check req-icon"></i> One number
            </li>
            <li class="req-item" data-req="req-special">
              <i class="fa-solid fa-circle-check req-icon"></i> One special character (!@#$%^&amp;*)
            </li>
          </ul>
        </div>


</div>

      <div class="form-actions">
        <%= f.button :submit, "Create Account" %>
      </div>

      <p class="auth-tos">
        By signing up, you agree to Reflekto's
        <%= link_to "Terms of Service", terms_path %> and
        <%= link_to "Privacy Policy", privacy_path %>.
      </p>

    <% end %>

    <div class="auth-links">
      <div class="auth-link-row">
        Already have an account?
        <%= link_to "Sign in", new_session_path(resource_name) %>
      </div>
    </div>

  </div>

</div>

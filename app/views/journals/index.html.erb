<div class="all-entries">

  <div class="all-entries__header">
    <h1 class="all-entries__title">All Entries</h1>
    <% if @stats[:total_entries] > 0 %>
      <div class="all-entries__stats">
        <span><strong><%= @stats[:total_entries] %></strong> <%= "entry".pluralize(@stats[:total_entries]) %></span>
        <span class="all-entries__stats-sep">·</span>
        <span><strong><%= number_with_delimiter(@stats[:total_words]) %></strong> words</span>
        <span class="all-entries__stats-sep">·</span>
        <span><strong><%= @stats[:current_streak] %></strong> day streak</span>
      </div>
    <% end %>
  </div>

  <% if @all_entries.any? %>
    <% @all_entries.group_by { |e| e.entry_date.strftime("%B %Y") }.each do |month, entries| %>
      <div class="all-entries__month-group">
        <div class="all-entries__month-label"><%= month %></div>
        <div class="entries__list">
          <% entries.each do |entry| %>
            <div class="entry-card">

              <div class="entry-card__date">
                <span class="entry-card__day"><%= entry.entry_date.strftime("%-d") %></span>
                <span class="entry-card__month"><%= entry.entry_date.strftime("%b") %></span>
              </div>

              <%= link_to journal_journal_entry_path(entry.journal, entry), class: "entry-card__link" do %>
                <div class="entry-card__title"><%= entry.title %></div>
                <div class="entry-card__preview"><%= entry.content.to_plain_text.truncate(120) %></div>
                <div class="entry-card__meta">
                  <span class="entry-journal-dot" style="background: <%= entry.journal.color || '#7C6FF7' %>"></span>
                  <span class="entry-journal-name"><%= entry.journal.name %></span>
                  <% entry.tags.each do |tag| %>
                    <span class="entry-tag-badge"><%= tag.name %></span>
                  <% end %>
                </div>
              <% end %>

              <div class="entry-card__actions">
                <%= link_to edit_journal_journal_entry_path(entry.journal, entry), class: "entry-action", title: "Edit" do %>
                  <i class="fa-solid fa-pen"></i>
                <% end %>
                <%= link_to journal_journal_entry_path(entry.journal, entry),
                    class: "entry-action entry-action--delete",
                    title: "Delete",
                    data: { turbo_method: :delete, turbo_confirm: "Delete \"#{entry.title}\"? This cannot be undone." } do %>
                  <i class="fa-solid fa-trash-can"></i>
                <% end %>
              </div>

            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  <% else %>
    <div class="all-entries__empty">
      <div class="all-entries__empty-icon">
        <i class="fa-solid fa-book-open"></i>
      </div>
      <% if @sidebar_journals.any? %>
        <div class="all-entries__empty-title">No entries yet</div>
        <p class="all-entries__empty-text">
          Choose a journal from the sidebar and write your first entry.
        </p>
      <% else %>
        <div class="all-entries__empty-title">Welcome to Reflekto</div>
        <p class="all-entries__empty-text">
          Create your first journal to start capturing your thoughts, reflections, and memories.
        </p>
        <%= link_to new_journal_path, class: "sidebar__new-entry-btn" do %>
          <i class="fa-solid fa-plus"></i> Create Your First Journal
        <% end %>
      <% end %>
    </div>
  <% end %>

</div>

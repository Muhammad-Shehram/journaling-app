    <span class="ln-pillar"><i class="fa-solid fa-lock" aria-hidden="true"></i> End-to-end private</span>
    <span class="ln-pillar-sep" aria-hidden="true">·</span>
    <span class="ln-pillar"><i class="fa-solid fa-book-open" aria-hidden="true"></i> Multiple journals</span>
    <span class="ln-pillar-sep" aria-hidden="true">·</span>
    <span class="ln-pillar"><i class="fa-solid fa-pen-nib" aria-hidden="true"></i> Rich text &amp; photos</span>
    <span class="ln-pillar-sep" aria-hidden="true">·</span>
    <span class="ln-pillar"><i class="fa-solid fa-tags" aria-hidden="true"></i> Tags &amp; search</span>

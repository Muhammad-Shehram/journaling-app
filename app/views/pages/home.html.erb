<%# ============================================ %>
<%# REFLEKTO LANDING PAGE                       %>
<%# ============================================ %>

<%# ---- NAVBAR (logged-out only) ---- %>
<nav class="landing-nav">
  <div class="container d-flex align-items-center justify-content-between">
    <div class="landing-nav__brand">Reflekto</div>
    <div class="landing-nav__actions">
      <%= link_to "Sign In", new_user_session_path, class: "landing-nav__link" %>
      <%= link_to "Get Started", new_user_registration_path, class: "landing-nav__cta" %>
    </div>
  </div>
</nav>

<%# ---- HERO SECTION ---- %>
<section class="hero-section">
  <div class="hero-glow hero-glow--top"></div>
  <div class="hero-glow hero-glow--bottom"></div>

  <div class="container position-relative">
    <div class="row justify-content-center text-center">
      <div class="col-lg-8 col-md-10">
        <div class="hero-badge">✦ Your private journaling space</div>
        <h1 class="hero-title">Your Journal.<br>Your Story.</h1>
        <p class="hero-subtitle">
          Reflekto gives you a private, beautifully organized space to capture
          your thoughts, memories, and daily reflections — all in one place.
        </p>
        <div class="hero-actions">
          <%= link_to "Start Writing Free", new_user_registration_path, class: "btn btn-reflekto-primary" %>
          <%= link_to "Sign In", new_user_session_path, class: "btn btn-reflekto-ghost" %>
        </div>
        <p class="hero-footnote">Free to use &nbsp;·&nbsp; No credit card required</p>
      </div>
    </div>
  </div>

  <div class="hero-scroll-hint">
    <i class="fa-solid fa-chevron-down"></i>
  </div>
</section>

<%# ---- TRUST BAR ---- %>
<section class="trust-bar">
  <div class="container">
    <div class="row justify-content-center align-items-center g-0">
      <div class="col-auto trust-item">
        <i class="fa-solid fa-lock"></i> End-to-end private
      </div>
      <span class="trust-divider">·</span>
      <div class="col-auto trust-item">
        <i class="fa-solid fa-book-open"></i> Multiple journals
      </div>
      <span class="trust-divider">·</span>
      <div class="col-auto trust-item">
        <i class="fa-solid fa-face-smile"></i> Mood tracking
      </div>
      <span class="trust-divider">·</span>
      <div class="col-auto trust-item">
        <i class="fa-solid fa-globe"></i> Access anywhere
      </div>
    </div>
  </div>
</section>

<%# ---- FEATURES SECTION ---- %>
<section class="features-section">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-label">Why Reflekto</span>
      <h2 class="section-title">Everything you need to journal well</h2>
      <p class="section-subtitle">Simple, focused tools that get out of the way and let you write.</p>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fa-solid fa-book-bookmark"></i>
          </div>
          <h3>Multiple Journals</h3>
          <p>Separate notebooks for work, personal life, travel, ideas. Your thoughts stay organized, always.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="feature-card feature-card--dark">
          <div class="feature-icon feature-icon--light">
            <i class="fa-solid fa-lock"></i>
          </div>
          <h3>Completely Private</h3>
          <p>Your journal belongs only to you. No sharing, no algorithms, no ads. Just your thoughts and a blank page.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fa-solid fa-pen-nib"></i>
          </div>
          <h3>Rich Entries</h3>
          <p>Log your mood, pick a date, write freely. Every entry is a vivid snapshot of your life.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ---- HOW IT WORKS ---- %>
<section class="how-section">
  <div class="container">
    <div class="text-center mb-5">
      <span class="section-label">Getting started</span>
      <h2 class="section-title">Start in 60 seconds</h2>
    </div>

    <div class="row align-items-start justify-content-center">
      <div class="col-md-3 text-center how-step">
        <div class="step-number">01</div>
        <h4>Create an account</h4>
        <p>Sign up free. No credit card, no nonsense. You're in within seconds.</p>
      </div>

      <div class="col-md-1 step-arrow d-none d-md-flex">
        <i class="fa-solid fa-arrow-right"></i>
      </div>

      <div class="col-md-3 text-center how-step">
        <div class="step-number">02</div>
        <h4>Create a journal</h4>
        <p>Name it whatever fits — "Daily Log", "Travel", "Work Notes". Make it yours.</p>
      </div>

      <div class="col-md-1 step-arrow d-none d-md-flex">
        <i class="fa-solid fa-arrow-right"></i>
      </div>

      <div class="col-md-3 text-center how-step">
        <div class="step-number">03</div>
        <h4>Start writing</h4>
        <p>Log your mood, write freely. Your story starts today.</p>
      </div>
    </div>
  </div>
</section>

<%# ---- QUOTE SECTION ---- %>
<section class="quote-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7 text-center">
        <blockquote class="landing-quote">
          "The act of writing is the act of discovering what you believe."
        </blockquote>
        <cite class="landing-cite">— David Hare</cite>
      </div>
    </div>
  </div>
</section>

<%# ---- FINAL CTA ---- %>
<section class="cta-section">
  <div class="container text-center">
    <h2>Ready to start your journal?</h2>
    <p>Your story is worth keeping. Start today — it's free.</p>
    <%= link_to "Create your free journal", new_user_registration_path, class: "btn btn-cta-light" %>
  </div>
</section>

<%# ---- FOOTER ---- %>
<footer class="landing-footer">
  <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div class="footer-brand">Reflekto</div>
    <div class="footer-links">
      <%= link_to "Sign In", new_user_session_path %>
      <%= link_to "Get Started", new_user_registration_path %>
    </div>
    <div class="footer-copy">© 2026 Reflekto. All rights reserved.</div>
  </div>
</footer>

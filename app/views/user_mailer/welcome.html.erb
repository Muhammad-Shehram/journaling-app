<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #0f0f1a; color: #e8e8f0; margin: 0; padding: 0; }
      .wrapper { max-width: 520px; margin: 40px auto; padding: 0 20px; }
      .card { background: #1a1a2e; border-radius: 12px; padding: 36px 32px; border: 1px solid #2a2a4a; }
      .brand { font-size: 22px; font-weight: 700; color: #8b7cf8; margin-bottom: 24px; }
      h1 { font-size: 20px; font-weight: 600; color: #e8e8f0; margin: 0 0 12px; }
      p { font-size: 15px; line-height: 1.6; color: #9090b0; margin: 0 0 20px; }
      .cta { display: inline-block; background: #7C6FF7; color: #fff; text-decoration: none; font-weight: 600; font-size: 15px; padding: 12px 28px; border-radius: 8px; }
      .feature-list { list-style: none; padding: 0; margin: 0 0 24px; }
      .feature-list li { padding: 6px 0; font-size: 14px; color: #9090b0; }
      .feature-list li::before { content: "✦ "; color: #8b7cf8; }
      .footer { margin-top: 28px; font-size: 12px; color: #555570; text-align: center; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="card">
        <div class="brand">Reflekto</div>
        <h1>Welcome<%= @user.name.present? ? ", #{@user.name}" : "" %> 🎉</h1>
        <p>Your private journal is ready. Everything you write stays yours.</p>
        <ul class="feature-list">
          <li>Rich text entries with photos</li>
          <li>Tags &amp; full-text search</li>
          <li>Daily writing reminders</li>
          <li>30-day soft delete &amp; recovery</li>
        </ul>
        <%= link_to "Start writing", authenticated_root_url, class: "cta" %>
      </div>
      <div class="footer">
        You're receiving this because you just created a Reflekto account.
      </div>
    </div>
  </body>
</html>
